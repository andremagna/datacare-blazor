@namespace DataCareLite.Components.Layout
@inherits LayoutComponentBase

<div class="shell @(_sidebarCollapsed ? "sb-collapsed" : "")">

    <nav class="sidebar">
        <div class="sb-brand">
            @if (!_sidebarCollapsed)
            {
                <span class="sb-brand-logo">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                        <rect x="2"  y="2"  width="9" height="9" rx="2" fill="#4a90d9" />
                        <rect x="13" y="2"  width="9" height="9" rx="2" fill="#4a90d9" opacity=".6" />
                        <rect x="2"  y="13" width="9" height="9" rx="2" fill="#4a90d9" opacity=".6" />
                        <rect x="13" y="13" width="9" height="9" rx="2" fill="#4a90d9" opacity=".3" />
                    </svg>
                    <span class="sb-brand-name">DataCare</span>
                </span>
            }
            else
            {
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <rect x="2"  y="2"  width="9" height="9" rx="2" fill="#4a90d9" />
                    <rect x="13" y="2"  width="9" height="9" rx="2" fill="#4a90d9" opacity=".6" />
                    <rect x="2"  y="13" width="9" height="9" rx="2" fill="#4a90d9" opacity=".6" />
                    <rect x="13" y="13" width="9" height="9" rx="2" fill="#4a90d9" opacity=".3" />
                </svg>
            }
        </div>

        <ul class="sb-nav">
            <!-- Home -->
            <li>
                <a href="/" class="sb-link @(CurrentPage == "home" ? "sb-active" : "")">
                    <svg class="sb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        <polyline points="9 22 9 12 15 12 15 22" />
                    </svg>
                    @if (!_sidebarCollapsed)
                    {
                        <span>Home</span>
                    }
                </a>
            </li>

            <!-- Logs (between Home and Dashboard) -->
            <li>
                <a href="/logs" class="sb-link @(CurrentPage == "logs" ? "sb-active" : "")">
                    <svg class="sb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="3" />
                        <line x1="7" y1="8"  x2="17" y2="8"  stroke-linecap="round" />
                        <line x1="7" y1="12" x2="14" y2="12" stroke-linecap="round" />
                        <line x1="7" y1="16" x2="11" y2="16" stroke-linecap="round" />
                    </svg>
                    @if (!_sidebarCollapsed)
                    {
                        <span>Logs</span>
                    }
                </a>
            </li>

            <!-- Dashboard -->
            <li>
                <a href="/dashboard" class="sb-link @(CurrentPage == "dashboard" ? "sb-active" : "")">
                    <svg class="sb-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3"  y="3"  width="7" height="7" />
                        <rect x="14" y="3"  width="7" height="7" />
                        <rect x="14" y="14" width="7" height="7" />
                        <rect x="3"  y="14" width="7" height="7" />
                    </svg>
                    @if (!_sidebarCollapsed)
                    {
                        <span>Dashboard</span>
                    }
                </a>
            </li>
        </ul>

        <button class="sb-collapse-btn" @onclick="ToggleSidebar"
                title="@(_sidebarCollapsed ? "Espandi" : "Comprimi")">
            @if (_sidebarCollapsed)
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <polyline points="9 18 15 12 9 6" />
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
            }
        </button>
    </nav>

    <div class="main-area">
        <div class="topbar">
            <span class="topbar-title">DataCare ETL &mdash; v1.0.0 &nbsp;&middot;&nbsp; Business Integration Partners</span>
        </div>
        <div class="page-body">
            @Body
        </div>
    </div>
</div>

@code {
    private bool _sidebarCollapsed = false;

    private string CurrentPage
    {
        get
        {
            var uri = NavigationManager?.Uri ?? "";
            if (uri.Contains("/dashboard")) return "dashboard";
            if (uri.Contains("/logs"))      return "logs";
            return "home";
        }
    }

    [Inject] private NavigationManager? NavigationManager { get; set; }

    private void ToggleSidebar() => _sidebarCollapsed = !_sidebarCollapsed;
}
