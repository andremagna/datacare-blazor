@page "/dashboard"
@using DataCareLite.Models
@using DataCareLite.Services
@using Microsoft.Data.SqlClient
@inject EtlStateService State
@implements IDisposable

<PageTitle>DataCare Dashboard</PageTitle>

@if (!State.HasRun)
{
    <div class="dash-empty">
        <div class="dash-empty-icon">
            <svg viewBox="0 0 64 64" fill="none" width="64" height="64">
                <rect x="4" y="4" width="26" height="26" rx="4" fill="#1a3a6b" opacity=".5" />
                <rect x="34" y="4" width="26" height="26" rx="4" fill="#1a3a6b" opacity=".3" />
                <rect x="4" y="34" width="26" height="26" rx="4" fill="#1a3a6b" opacity=".3" />
                <rect x="34" y="34" width="26" height="26" rx="4" fill="#1a3a6b" opacity=".15" />
            </svg>
        </div>
        <h2 class="dash-empty-title">Nessun dato disponibile</h2>
        <p class="dash-empty-msg">
            Inserisci i valori obbligatori ed esegui il <strong>Run ETL</strong>
            dalla pagina <a href="/">Home</a> per visualizzare la dashboard.
        </p>
    </div>
}
else if (!State.LastRunSuccess)
{
    <div class="dash-error-page">
        <div class="dash-error-icon">&#9888;</div>
        <h2 class="dash-error-title">Ops, errore imprevisto</h2>
        <p class="dash-error-msg">
            Si &egrave; verificato un errore durante l'esecuzione dell'ETL.<br />
            Torna alla pagina <a href="/">Home</a> e riesegui l'ETL.
        </p>
    </div>
}
else if (_loading)
{
    <div class="dash-empty">
        <p class="dash-empty-msg">Caricamento dati dashboard...</p>
    </div>
}
else
{
    <div class="dashboard-page">
        <div class="dash-header">
            <div>
                <h1 class="dash-title">DataCare Dashboard</h1>
                <span class="dash-sub">Microsoft 365 Usage Report</span>
            </div>
            <div class="dept-filter">
                <label class="dept-label">Department</label>
                <select class="dept-select" @bind="_selectedDept" @bind:after="OnDeptChanged">
                    <option value="">All departments</option>
                    @foreach (var d in _departments)
                    {
                        <option value="@d">@d</option>
                    }
                </select>
            </div>
        </div>

        <!-- ═══════════════════ USERS ═══════════════════ -->
        <div class="section-band">
            <span class="section-band-title">Users</span>
        </div>
        <div class="cards-row mb-sm">
            <div class="dcard">
                <div class="dcard-title">Number of users</div>
                <svg viewBox="0 0 200 110" class="dchart">
                    @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.Users_Total)).ToList(), "#4a90d9")
                </svg>
            </div>
            <div class="dcard dcard-map">
                <div class="dcard-title">Country Involved</div>
                <div class="country-table-wrap">
                    <table class="ctable">
                        <thead><tr><th>Country</th><th class="ct-num">Count</th></tr></thead>
                        <tbody>
                        @foreach (var c in _countries.Take(10))
                        {
                            <tr><td>@c.CountryName</td><td class="ct-num">@c.CountryCount</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ═══════ ONEDRIVE + SHAREPOINT (side by side) ═══════ -->
        <div class="two-sections-row mb-sm">
            <div class="section-col">
                <div class="section-band section-band-blue">
                    <span class="section-band-title">OneDrive</span>
                </div>
                <div class="cards-row no-mb">
                    <div class="dcard">
                        <div class="dcard-title">File Count</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.OneDrive_Total_File_Count)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                    <div class="dcard">
                        <div class="dcard-title">File Storage (GB)</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.OneDrive_Total_StorageUsedGB)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                </div>
            </div>
            <div class="section-col">
                <div class="section-band section-band-teal">
                    <span class="section-badge-sp">S</span>
                    <span class="section-band-title">SharePoint</span>
                </div>
                <div class="cards-row no-mb">
                    <div class="dcard">
                        <div class="dcard-title">File Count</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.SharePoint_Total_File_Count)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                    <div class="dcard">
                        <div class="dcard-title">File Storage (GB)</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.SharePoint_Total_StorageUsedGB)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════ EXCHANGE ═══════════════════ -->
        <div class="section-band section-band-dark">
            <span class="section-badge-ex">E</span>
            <span class="section-band-title">Exchange</span>
        </div>
        <div class="exchange-row">
            <!-- Primary -->
            <div class="exchange-col">
                <div class="exchange-sub-header">Primary</div>
                <div class="cards-row no-mb">
                    <div class="dcard">
                        <div class="dcard-title">Email Count</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.Exchange_Total_Primary_Item_Count)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                    <div class="dcard">
                        <div class="dcard-title">Email Storage (GB)</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.Exchange_Total_Primary_Total_Size_GB)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                    <div class="dcard">
                        <div class="dcard-title">Other Details</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyGroupedBarChart(
                                _data.Select(r => r.MonthLabel).ToList(),
                                new List<(string, Func<DashRow, double>, string)> {
                                    ("Sys Msg",     r => (double)r.Exchange_Total_Primary_SystemMessage_Count, "#e975a8"),
                                    ("Recoverable", r => (double)r.Exchange_Total_Primary_Recoverable_Count,  "#4a90d9"),
                                },
                                _data
                            )
                        </svg>
                    </div>
                </div>
            </div>
            <!-- Archive -->
            <div class="exchange-col">
                <div class="exchange-sub-header">Archive</div>
                <div class="cards-row no-mb">
                    <div class="dcard">
                        <div class="dcard-title">Email Count</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.Exchange_Total_Archive_Item_Count)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                    <div class="dcard">
                        <div class="dcard-title">Email Storage (GB)</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyBarChart(_data.Select(r => (r.MonthLabel, (double)r.Exchange_Total_Archive_Total_Size_GB)).ToList(), "#4a90d9")
                        </svg>
                    </div>
                    <div class="dcard">
                        <div class="dcard-title">Other Details</div>
                        <svg viewBox="0 0 200 110" class="dchart">
                            @MonthlyGroupedBarChart(
                                _data.Select(r => r.MonthLabel).ToList(),
                                new List<(string, Func<DashRow, double>, string)> {
                                    ("Sys Msg",     r => (double)r.Exchange_Total_Archive_SystemMessage_Count, "#e975a8"),
                                    ("Recoverable", r => (double)r.Exchange_Total_Archive_Recoverable_Count,   "#4a90d9"),
                                },
                                _data
                            )
                        </svg>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

@code {
    private bool _loading = true;
    private List<DashRow>    _data        = new();
    private List<CountryRow> _countries   = new();
    private List<string>     _departments = new();
    private string           _selectedDept = "";

    protected override async Task OnInitializedAsync()
    {
        State.OnChanged += OnStateChanged;
        if ((State.HasRun && State.LastRunSuccess) || !string.IsNullOrWhiteSpace(State.LastConnectionString))
            await LoadDataAsync();
        else
            _loading = false;
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        var cs = State.LastConnectionString;
        if (string.IsNullOrWhiteSpace(cs)) { _loading = false; return; }

        try
        {
            await EnsureHistoryPopulatedAsync(cs);

            if (_departments.Count == 0)
                _departments = await QueryListAsync(cs, TableDdl.DepartmentListQuery(), r => r.GetString(0));

            // One row per calendar month (full history, not just last run)
            _data = await QueryListAsync(cs, TableDdl.DashboardQuery(_selectedDept), r => new DashRow
            {
                MonthLabel  = r.IsDBNull(0)  ? "" : r.GetString(0),
                YearNum     = r.IsDBNull(1)  ? 0  : r.GetInt32(1),
                MonthNum    = r.IsDBNull(2)  ? 0  : r.GetInt32(2),
                Exchange_Total_Primary_Item_Count               = r.IsDBNull(3)  ? 0 : r.GetInt64(3),
                Exchange_Total_Archive_Item_Count               = r.IsDBNull(4)  ? 0 : r.GetInt64(4),
                Exchange_Total_Primary_Total_Size_GB            = r.IsDBNull(5)  ? 0 : (double)r.GetDecimal(5),
                Exchange_Total_Archive_Total_Size_GB            = r.IsDBNull(6)  ? 0 : (double)r.GetDecimal(6),
                Exchange_Total_Primary_SystemMessage_Count      = r.IsDBNull(7)  ? 0 : r.GetInt64(7),
                Exchange_Total_Primary_SystemMessage_Size_Bytes = r.IsDBNull(8)  ? 0 : r.GetInt64(8),
                Exchange_Total_Primary_Recoverable_Count        = r.IsDBNull(9)  ? 0 : r.GetInt64(9),
                Exchange_Total_Primary_Recoverable_Size_Bytes   = r.IsDBNull(10) ? 0 : r.GetInt64(10),
                Exchange_Total_Archive_SystemMessage_Count      = r.IsDBNull(11) ? 0 : r.GetInt64(11),
                Exchange_Total_Archive_SystemMessage_Size_Bytes = r.IsDBNull(12) ? 0 : r.GetInt64(12),
                Exchange_Total_Archive_Recoverable_Count        = r.IsDBNull(13) ? 0 : r.GetInt64(13),
                Exchange_Total_Archive_Recoverable_Size_Bytes   = r.IsDBNull(14) ? 0 : r.GetInt64(14),
                Exchange_Total_Archive_Total_Size_Bytes         = r.IsDBNull(15) ? 0 : r.GetInt64(15),
                OneDrive_Total_File_Count                       = r.IsDBNull(16) ? 0 : r.GetInt64(16),
                OneDrive_Total_StorageUsedGB                    = r.IsDBNull(17) ? 0 : (double)r.GetDecimal(17),
                SharePoint_Total_File_Count                     = r.IsDBNull(18) ? 0 : r.GetInt64(18),
                SharePoint_Total_StorageUsedGB                  = r.IsDBNull(19) ? 0 : (double)r.GetDecimal(19),
                Users_Total                                     = r.IsDBNull(20) ? 0 : r.GetInt32(20),
            });

            _countries = await QueryListAsync(cs, TableDdl.CountryQuery(_selectedDept), r => new CountryRow
            {
                CountryName  = r.IsDBNull(0) ? "Unknown" : r.GetString(0),
                CountryCount = r.IsDBNull(1) ? 0         : r.GetInt32(1),
            });
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task OnDeptChanged() { await LoadDataAsync(); StateHasChanged(); }

    private void OnStateChanged() => _ = InvokeAsync(async () =>
    {
        if (State.HasRun && State.LastRunSuccess) await LoadDataAsync();
        StateHasChanged();
    });

    public void Dispose() => State.OnChanged -= OnStateChanged;

    private static async Task EnsureHistoryPopulatedAsync(string cs)
    {
        await using var conn = new SqlConnection(cs);
        await conn.OpenAsync();
        await using var checkCmd = new SqlCommand(
            "SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='PowerBIDataModelHistory'", conn);
        if ((int)(await checkCmd.ExecuteScalarAsync())! == 0) return;

        await using var countCmd = new SqlCommand("SELECT COUNT(*) FROM dbo.PowerBIDataModelHistory", conn);
        if ((int)(await countCmd.ExecuteScalarAsync())! > 0) return;

        await using var srcCmd = new SqlCommand(
            "SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME IN ('MicrosoftExchange','MicrosoftOneDrive','MicrosoftSharePoint','MicrosoftUsers')", conn);
        if ((int)(await srcCmd.ExecuteScalarAsync())! < 4) return;

        var execId = Guid.NewGuid();
        var sql = $"DECLARE @ExecutionId UNIQUEIDENTIFIER = '{execId}';\n" + TableDdl.PowerBIAggregateQuery;
        await using var cmd = new SqlCommand(sql, conn) { CommandTimeout = 180 };
        await cmd.ExecuteNonQueryAsync();
    }

    private static async Task<List<T>> QueryListAsync<T>(string cs, string sql, Func<SqlDataReader, T> map)
    {
        var list = new List<T>();
        await using var conn = new SqlConnection(cs);
        await conn.OpenAsync();
        await using var cmd = new SqlCommand(sql, conn);
        await using var rdr = await cmd.ExecuteReaderAsync();
        while (await rdr.ReadAsync()) list.Add(map(rdr));
        return list;
    }

    // ── SVG bar chart — one bar per month ─────────────────────────────────────
    private RenderFragment MonthlyBarChart(List<(string Month, double Val)> data, string color) => b =>
    {
        if (data == null || data.Count == 0) return;
        const double left = 28, top = 6, right = 194, bottom = 88;
        double chartW = right - left, chartH = bottom - top;
        double max = data.Max(d => d.Val);
        int n = data.Count;
        double barW = Math.Min(30, (chartW - 4 * (n + 1)) / Math.Max(n, 1));
        double gap  = (chartW - barW * n) / (n + 1);

        SvgLine(b, 0, left, top, left, bottom);
        SvgLine(b, 1, left, bottom, right, bottom);

        for (int yi = 0; yi <= 2; yi++)
        {
            double yv = max * yi / 2.0;
            double yp = bottom - (max > 0 ? (yv / max) * chartH : 0);
            SvgText(b, 20 + yi, FormatLargeNum(yv), left - 2, yp + 2, "end", "#8899bb", "6.5");
        }

        for (int i = 0; i < n; i++)
        {
            double v    = data[i].Val;
            double barH = max > 0 ? (v / max) * chartH : 2;
            double x    = left + gap + i * (barW + gap);
            double y    = bottom - Math.Max(2, barH);

            b.OpenElement(100 + i, "rect");
            b.AddAttribute(0, "x",      x.ToString("F1"));
            b.AddAttribute(0, "y",      y.ToString("F1"));
            b.AddAttribute(0, "width",  barW.ToString("F1"));
            b.AddAttribute(0, "height", Math.Max(2, barH).ToString("F1"));
            b.AddAttribute(0, "rx",     "2");
            b.AddAttribute(0, "fill",   color);
            b.CloseElement();

            SvgText(b, 200 + i, FormatLargeNum(v),   x + barW / 2, y - 2,      "middle", "#c8d8f0", "6");
            SvgText(b, 300 + i, data[i].Month,        x + barW / 2, bottom + 9, "middle", "#7090b0", "6");
        }
    };

    // ── Grouped bar chart — multiple series per month (Exchange Other Details) ─
    private RenderFragment MonthlyGroupedBarChart(
        List<string> months,
        List<(string Label, Func<DashRow, double> Get, string Color)> series,
        List<DashRow> rows) => b =>
    {
        if (rows == null || rows.Count == 0 || series.Count == 0) return;
        const double left = 28, top = 6, right = 194, bottom = 88;
        double chartW = right - left, chartH = bottom - top;
        int n = rows.Count, s = series.Count;
        double groupW  = chartW / Math.Max(n, 1);
        double barW    = Math.Min(14, (groupW - 4) / s);
        double max     = rows.SelectMany(r => series.Select(sv => sv.Get(r))).DefaultIfEmpty(1).Max();

        SvgLine(b, 0, left, top, left, bottom);
        SvgLine(b, 1, left, bottom, right, bottom);

        for (int yi = 0; yi <= 2; yi++)
        {
            double yv = max * yi / 2.0;
            double yp = bottom - (max > 0 ? (yv / max) * chartH : 0);
            SvgText(b, 20 + yi, FormatLargeNum(yv), left - 2, yp + 2, "end", "#8899bb", "6.5");
        }

        for (int i = 0; i < n; i++)
        {
            double groupX = left + i * groupW + (groupW - barW * s - 2 * (s - 1)) / 2;
            double midX   = left + i * groupW + groupW / 2;
            for (int si = 0; si < s; si++)
            {
                double v    = series[si].Get(rows[i]);
                double barH = max > 0 ? (v / max) * chartH : 2;
                double x    = groupX + si * (barW + 2);
                double y    = bottom - Math.Max(2, barH);

                b.OpenElement(100 + i * 10 + si, "rect");
                b.AddAttribute(0, "x",      x.ToString("F1"));
                b.AddAttribute(0, "y",      y.ToString("F1"));
                b.AddAttribute(0, "width",  barW.ToString("F1"));
                b.AddAttribute(0, "height", Math.Max(2, barH).ToString("F1"));
                b.AddAttribute(0, "rx",     "1.5");
                b.AddAttribute(0, "fill",   series[si].Color);
                b.CloseElement();

                SvgText(b, 200 + i * 10 + si, FormatLargeNum(v), x + barW / 2, y - 2, "middle", "#c8d8f0", "5.5");
            }
            SvgText(b, 300 + i, months[i], midX, bottom + 9, "middle", "#7090b0", "6");
        }
    };

    private static void SvgLine(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b,
        int key, double x1, double y1, double x2, double y2)
    {
        b.OpenElement(key, "line");
        b.AddAttribute(0, "x1", x1); b.AddAttribute(0, "y1", y1);
        b.AddAttribute(0, "x2", x2); b.AddAttribute(0, "y2", y2);
        b.AddAttribute(0, "stroke", "#2a2a44"); b.AddAttribute(0, "stroke-width", "0.7");
        b.CloseElement();
    }

    private static void SvgText(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder b,
        int key, string content, double x, double y, string anchor, string fill, string size)
    {
        b.OpenElement(key, "text");
        b.AddAttribute(0, "x", x.ToString("F1")); b.AddAttribute(0, "y", y.ToString("F1"));
        b.AddAttribute(0, "fill", fill); b.AddAttribute(0, "font-size", size);
        b.AddAttribute(0, "text-anchor", anchor);
        b.AddContent(0, content);
        b.CloseElement();
    }

    private static string FormatLargeNum(double v)
    {
        if (v >= 1_000_000_000) return $"{v / 1_000_000_000:F1}B";
        if (v >= 1_000_000)     return $"{v / 1_000_000:F2}Mln";
        if (v >= 1_000)         return $"{v / 1_000:F1}K";
        return v.ToString("F0");
    }

    // ── Models ────────────────────────────────────────────────────────────────
    private class DashRow
    {
        public string MonthLabel { get; set; } = "";
        public int    YearNum    { get; set; }
        public int    MonthNum   { get; set; }
        public long   Exchange_Total_Primary_Item_Count               { get; set; }
        public long   Exchange_Total_Archive_Item_Count               { get; set; }
        public double Exchange_Total_Primary_Total_Size_GB            { get; set; }
        public double Exchange_Total_Archive_Total_Size_GB            { get; set; }
        public long   Exchange_Total_Primary_SystemMessage_Count      { get; set; }
        public long   Exchange_Total_Primary_SystemMessage_Size_Bytes { get; set; }
        public long   Exchange_Total_Primary_Recoverable_Count        { get; set; }
        public long   Exchange_Total_Primary_Recoverable_Size_Bytes   { get; set; }
        public long   Exchange_Total_Archive_SystemMessage_Count      { get; set; }
        public long   Exchange_Total_Archive_SystemMessage_Size_Bytes { get; set; }
        public long   Exchange_Total_Archive_Recoverable_Count        { get; set; }
        public long   Exchange_Total_Archive_Recoverable_Size_Bytes   { get; set; }
        public long   Exchange_Total_Archive_Total_Size_Bytes         { get; set; }
        public long   OneDrive_Total_File_Count                       { get; set; }
        public double OneDrive_Total_StorageUsedGB                    { get; set; }
        public long   SharePoint_Total_File_Count                     { get; set; }
        public double SharePoint_Total_StorageUsedGB                  { get; set; }
        public int    Users_Total                                     { get; set; }
    }

    private class CountryRow
    {
        public string CountryName  { get; set; } = "";
        public int    CountryCount { get; set; }
    }
}

<style>
    /* ── Department filter ─── */
    .dept-filter  { display:flex; align-items:center; gap:.6rem; margin-left:auto; }
    .dept-label   { font-size:.78rem; color:#7090c0; font-weight:600; }
    .dept-select  { background:#151528; border:1px solid #2a2a44; color:#c8d0e7;
                    border-radius:6px; padding:.4rem .8rem; font-size:.82rem;
                    outline:none; cursor:pointer; min-width:180px; }
    .dept-select:focus { border-color:#4a90d9; }

    /* ── Header ─── */
    .dash-header  { display:flex; align-items:flex-start; justify-content:space-between;
                    flex-wrap:wrap; gap:1rem; margin-bottom:1rem; }

    /* ── Section bands ─── */
    .section-band {
        display:flex; align-items:center; gap:.5rem;
        background:#12121e; border:1px solid #2a2a44; border-bottom:none;
        border-radius:6px 6px 0 0; padding:.4rem .9rem;
    }
    .section-band-dark { background:#0d0d1a; }
    .section-band-blue { background:#09182a; }
    .section-band-teal { background:#071815; }
    .section-band-title { font-size:.8rem; font-weight:700; color:#c8d8f0; letter-spacing:.04em; }
    .section-badge-sp {
        width:16px; height:16px; border-radius:3px; background:#036c70;
        color:#fff; font-size:.65rem; font-weight:700;
        display:inline-flex; align-items:center; justify-content:center;
    }
    .section-badge-ex {
        width:16px; height:16px; border-radius:3px; background:#0078d4;
        color:#fff; font-size:.65rem; font-weight:700;
        display:inline-flex; align-items:center; justify-content:center;
    }

    /* ── Cards ─── */
    .cards-row   { display:flex; gap:.6rem; flex-wrap:wrap; margin-bottom:.6rem; }
    .cards-row.no-mb { margin-bottom:0; }
    .mb-sm       { margin-bottom:.6rem; }
    .dcard {
        background:#12121e; border:1px solid #222236; border-top:none;
        border-radius:0 0 6px 6px; padding:.55rem .7rem; flex:1; min-width:0;
    }
    .dcard-map   { flex:2.2; }
    .dcard-title { font-size:.7rem; font-weight:600; color:#8899bb; margin-bottom:.3rem;
                   white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .dchart      { width:100%; height:auto; display:block; overflow:visible; }

    /* ── Country table ─── */
    .country-table-wrap { overflow-y:auto; max-height:140px; }
    .ctable      { width:100%; border-collapse:collapse; font-size:.72rem; }
    .ctable th   { color:#556680; font-weight:600; padding:2px 4px; border-bottom:1px solid #2a2a44; }
    .ctable td   { color:#a0b4cc; padding:2px 4px; }
    .ct-num      { text-align:right; color:#6ad0a0; font-weight:600; }

    /* ── Two-col layout (OneDrive | SharePoint) ─── */
    .two-sections-row { display:flex; gap:.6rem; margin-bottom:.6rem; }
