@page "/logs"
@using DataCareLite.Models
@using DataCareLite.Services
@using Microsoft.Data.SqlClient
@inject EtlStateService State
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>DataCare – Logs</PageTitle>

@if (_loading)
{
    <div class="logs-empty">
        <div class="dash-empty-icon">
            <svg viewBox="0 0 64 64" fill="none" width="48" height="48">
                <circle cx="32" cy="32" r="28" stroke="#1a3a6b" stroke-width="3" opacity=".4"/>
                <path d="M32 16v16l10 6" stroke="#4a90d9" stroke-width="3" stroke-linecap="round"/>
            </svg>
        </div>
        <p class="dash-empty-msg">Caricamento log in corso...</p>
    </div>
}
else if (!_hasData)
{
    <div class="logs-empty">
        <div class="dash-empty-icon">
            <svg viewBox="0 0 64 64" fill="none" width="56" height="56">
                <rect x="8" y="8" width="48" height="48" rx="6" stroke="#1a3a6b" stroke-width="2.5" opacity=".4"/>
                <line x1="18" y1="24" x2="46" y2="24" stroke="#4a90d9" stroke-width="2" stroke-linecap="round"/>
                <line x1="18" y1="33" x2="38" y2="33" stroke="#4a90d9" stroke-width="2" stroke-linecap="round" opacity=".5"/>
                <line x1="18" y1="42" x2="30" y2="42" stroke="#4a90d9" stroke-width="2" stroke-linecap="round" opacity=".25"/>
            </svg>
        </div>
        <h2 class="dash-empty-title">Nessun log disponibile</h2>
        <p class="dash-empty-msg">Esegui il <strong>Run ETL</strong> dalla pagina <a href="/">Home</a> per visualizzare i log di esecuzione.</p>
    </div>
}
else
{
    <div class="logs-page">
        <div class="dash-header">
            <div>
                <h1 class="dash-title">Execution Logs</h1>
                <span class="dash-sub">dbo.ExecutionLog — tutte le esecuzioni</span>
            </div>
            <div class="logs-filter-row">
                <input class="logs-search" type="text" placeholder="Cerca per ReportName, Status…"
                       @bind="_search" @bind:event="oninput" />
            </div>
        </div>

        <div class="logs-table-wrap">
            <table class="logs-table">
                <thead>
                    <tr>
                        <th @onclick="@(() => SortBy("ExecutionDate"))" class="sortable @(SortClass("ExecutionDate"))">Data</th>
                        <th @onclick="@(() => SortBy("ReportName"))" class="sortable @(SortClass("ReportName"))">Report</th>
                        <th @onclick="@(() => SortBy("Status"))" class="sortable @(SortClass("Status"))">Status</th>
                        <th @onclick="@(() => SortBy("RowsRetrieved"))" class="sortable @(SortClass("RowsRetrieved"))">Recuperate</th>
                        <th @onclick="@(() => SortBy("RowsInserted"))" class="sortable @(SortClass("RowsInserted"))">Inserite</th>
                        <th @onclick="@(() => SortBy("DurationSeconds"))" class="sortable @(SortClass("DurationSeconds"))">Durata (s)</th>
                        <th>Errore</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Filtered())
                    {
                        <tr class="@(r.IsSuccess ? "" : "log-row-err")">
                            <td class="log-date">@r.ExecutionDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@r.ReportName</td>
                            <td>
                                <span class="log-badge @(r.IsSuccess ? "badge-ok" : r.Status == "CANCELLED" ? "badge-warn" : "badge-err")">
                                    @r.Status
                                </span>
                            </td>
                            <td class="log-num">@r.RowsRetrieved.ToString("N0")</td>
                            <td class="log-num">@r.RowsInserted.ToString("N0")</td>
                            <td class="log-num">@r.DurationSeconds</td>
                            <td class="log-err">@(r.ErrorMessage ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="logs-footer">
                @_all.Count righe totali · @Filtered().Count() mostrate
            </div>
        </div>
    </div>
}

<style>
.logs-page { padding: 1.5rem 2rem; }
.logs-empty { display:flex; flex-direction:column; align-items:center; justify-content:center;
              min-height:55vh; gap:1rem; text-align:center; }
.logs-filter-row { display:flex; gap:.75rem; align-items:center; }
.logs-search { background:#151528; border:1px solid #2a2a44; color:#c8d0e7; border-radius:6px;
               padding:.4rem .8rem; font-size:.82rem; width:260px; outline:none; }
.logs-search::placeholder { color:#445; }
.logs-table-wrap { overflow-x:auto; margin-top:1.25rem; border-radius:10px;
                   border:1px solid #1e1e38; background:#10101f; }
.logs-table { width:100%; border-collapse:collapse; font-size:.82rem; }
.logs-table thead tr { background:#151528; }
.logs-table th { padding:.65rem .9rem; color:#7090c0; font-weight:600; text-align:left;
                 border-bottom:1px solid #1e1e38; white-space:nowrap; user-select:none; }
.logs-table th.sortable { cursor:pointer; }
.logs-table th.sortable:hover { color:#a0c0f0; }
.logs-table th.sort-asc::after  { content:" ▲"; font-size:.7em; }
.logs-table th.sort-desc::after { content:" ▼"; font-size:.7em; }
.logs-table td { padding:.55rem .9rem; border-bottom:1px solid #1a1a30; color:#b0bcd4;
                 vertical-align:top; }
.logs-table tr:last-child td { border-bottom:none; }
.logs-table tr:hover td { background:#13132a; }
.log-row-err td { background:#1a0f0f; }
.log-row-err:hover td { background:#1f1010; }
.log-date { white-space:nowrap; color:#778; font-family:monospace; }
.log-num  { text-align:right; font-family:monospace; }
.log-err  { color:#e07070; font-size:.78rem; max-width:280px; word-break:break-word; }
.log-badge { display:inline-block; padding:.15rem .55rem; border-radius:4px;
             font-size:.75rem; font-weight:700; letter-spacing:.03em; }
.badge-ok   { background:#0e3322; color:#4caf90; }
.badge-err  { background:#3a0f0f; color:#e07070; }
.badge-warn { background:#2a200a; color:#e0b050; }
.logs-footer { padding:.5rem 1rem; color:#445; font-size:.75rem; border-top:1px solid #1e1e38;
               text-align:right; }
</style>

@code {
    private List<ExecutionLogEntry> _all = new();
    private bool _loading = true;
    private bool _hasData = false;
    private string _search = string.Empty;
    private string _sortCol = "ExecutionDate";
    private bool _sortDesc = true;

    protected override async Task OnInitializedAsync()
    {
        State.OnChanged += OnStateChanged;
        await LoadLogsAsync();
    }

    private async Task LoadLogsAsync()
    {
        _loading = true;
        try
        {
            // Try to get connection string from state (last used run)
            var cs = State.LastConnectionString;
            if (string.IsNullOrWhiteSpace(cs))
            {
                _hasData = false;
                return;
            }
            var list = new List<ExecutionLogEntry>();
            await using var conn = new SqlConnection(cs);
            await conn.OpenAsync();
            await using var cmd = new SqlCommand(@"
                SELECT ExecutionDate, ReportName, Status,
                       RowsRetrieved, RowsInserted, DurationSeconds, ErrorMessage
                FROM dbo.ExecutionLog
                ORDER BY ExecutionDate DESC", conn);
            await using var rdr = await cmd.ExecuteReaderAsync();
            while (await rdr.ReadAsync())
                list.Add(new ExecutionLogEntry
                {
                    ExecutionDate   = rdr.GetDateTime(0),
                    ReportName      = rdr.GetString(1),
                    Status          = rdr.GetString(2),
                    RowsRetrieved   = rdr.IsDBNull(3) ? 0 : rdr.GetInt32(3),
                    RowsInserted    = rdr.IsDBNull(4) ? 0 : rdr.GetInt32(4),
                    DurationSeconds = rdr.IsDBNull(5) ? 0 : rdr.GetInt32(5),
                    ErrorMessage    = rdr.IsDBNull(6) ? null : rdr.GetString(6),
                });
            _all = list;
            _hasData = _all.Count > 0;
        }
        catch { _hasData = false; }
        finally { _loading = false; }
    }

    private IEnumerable<ExecutionLogEntry> Filtered()
    {
        var q = _all.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim().ToLowerInvariant();
            q = q.Where(r => r.ReportName.ToLower().Contains(s)
                           || r.Status.ToLower().Contains(s)
                           || (r.ErrorMessage?.ToLower().Contains(s) ?? false));
        }
        q = _sortCol switch
        {
            "ReportName"      => _sortDesc ? q.OrderByDescending(r => r.ReportName)      : q.OrderBy(r => r.ReportName),
            "Status"          => _sortDesc ? q.OrderByDescending(r => r.Status)           : q.OrderBy(r => r.Status),
            "RowsRetrieved"   => _sortDesc ? q.OrderByDescending(r => r.RowsRetrieved)   : q.OrderBy(r => r.RowsRetrieved),
            "RowsInserted"    => _sortDesc ? q.OrderByDescending(r => r.RowsInserted)    : q.OrderBy(r => r.RowsInserted),
            "DurationSeconds" => _sortDesc ? q.OrderByDescending(r => r.DurationSeconds) : q.OrderBy(r => r.DurationSeconds),
            _                 => _sortDesc ? q.OrderByDescending(r => r.ExecutionDate)   : q.OrderBy(r => r.ExecutionDate),
        };
        return q;
    }

    private void SortBy(string col)
    {
        if (_sortCol == col) _sortDesc = !_sortDesc;
        else { _sortCol = col; _sortDesc = true; }
    }

    private string SortClass(string col) =>
        _sortCol == col ? (_sortDesc ? "sort-desc" : "sort-asc") : "";

    private void OnStateChanged() => _ = InvokeAsync(async () =>
    {
        await LoadLogsAsync();
        StateHasChanged();
    });

    public void Dispose() => State.OnChanged -= OnStateChanged;
}
